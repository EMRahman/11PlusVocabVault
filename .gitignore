# Intermediate generation artifacts for the themed-sentence pipeline.
# The pipeline regenerates these; the final data lives in data/words.json.
scripts/batches/

# Intermediate prompt batches for Word Explorer enrichment (etymology + popularity).
# Regenerated by scripts/build-explorer-prompts.js; merged data lives in
# data/word-explorer.json.
scripts/explorer-prompts/

# Intermediate prompt batches for the multiple-meanings pipeline.
# Regenerated by scripts/build-meanings-prompts.js; merged senses live in
# data/words.json (each word's meanings[] array).
scripts/meanings-prompts/
